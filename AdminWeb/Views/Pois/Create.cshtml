@model AdminWeb.Models.PoiRecord

@{
    ViewData["Title"] = "Thêm POI";
}

<div class="container py-4" style="max-width: 980px;">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <h2 class="mb-1">Thêm địa điểm</h2>
            <div class="text-muted">Tạo bản ghi theo từng ngôn ngữ (vi/en/zh/ja).</div>
        </div>
        <a class="btn btn-outline-secondary" href="/pois">Quay lại</a>
    </div>

    <form method="post" action="/pois/create" class="mt-3">
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <label class="form-label">Code</label>
                <input class="form-control" asp-for="Code" placeholder="VD: HO_GUOM" />
                <span class="text-danger small" asp-validation-for="Code"></span>
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">Language</label>
                <select class="form-select" asp-for="LanguageCode">
                    <option value="vi">vi</option>
                    <option value="en">en</option>
                    <option value="zh">zh</option>
                    <option value="ja">ja</option>
                </select>
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label">Latitude</label>
                <input class="form-control" asp-for="Latitude" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">Longitude</label>
                <input class="form-control" asp-for="Longitude" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">Radius (m)</label>
                <input class="form-control" asp-for="Radius" />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label">Priority</label>
                <input class="form-control" asp-for="Priority" />
            </div>

            <div class="col-12">
                <label class="form-label">Name</label>
                <input class="form-control" asp-for="Name" />
            </div>
            <div class="col-12">
                <label class="form-label">Summary</label>
                <textarea class="form-control" asp-for="Summary" rows="2"></textarea>
            </div>
            <div class="col-12">
                <label class="form-label">NarrationShort</label>
                <textarea class="form-control" asp-for="NarrationShort" rows="3"></textarea>
            </div>
            <div class="col-12">
                <label class="form-label">NarrationLong</label>
                <textarea class="form-control" asp-for="NarrationLong" rows="5"></textarea>
                <div class="form-text">Nếu để trống, hệ thống sẽ tự dùng NarrationShort.</div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <button class="btn btn-primary" type="submit">Lưu</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

