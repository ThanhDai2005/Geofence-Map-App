<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="MauiApp1.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.BackgroundColor="{StaticResource BrandPrimary}"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White"
    Shell.UnselectedColor="#5C362B"
    Shell.TabBarBackgroundColor="{StaticResource SurfaceBackground}"
    Shell.TabBarForegroundColor="{StaticResource BrandPrimary}"
    Shell.TabBarUnselectedColor="{StaticResource BrandDark}"
    Shell.NavBarHasShadow="False">
</Shell>