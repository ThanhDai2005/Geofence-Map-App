<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp1.Views.ExplorePage"
    Title="Khám phá"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <RefreshView IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}"
                 RefreshColor="{StaticResource BrandPrimary}">
        <ScrollView>
            <VerticalStackLayout Padding="20,16,20,120" Spacing="22">

            <!-- HERO -->
            <Border Style="{StaticResource CardBorder}" Padding="0">
                <Grid RowDefinitions="320,Auto" RowSpacing="0">

                    <Grid>
                        <CarouselView x:Name="HeroCarousel"
                                      HeightRequest="320"
                                      IndicatorView="HeroIndicator">
                            <CarouselView.ItemsSource>
                                <x:Array Type="x:String">
                                    <x:String>cauvangdanang.jpg</x:String>
                                    <x:String>caobang.jpg</x:String>
                                    <x:String>chuabaidinh.jpg</x:String>
                                    <x:String>hoian.jpg</x:String>
                                </x:Array>
                            </CarouselView.ItemsSource>

                            <CarouselView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Image Source="{Binding .}" Aspect="AspectFill" />
                                        <Grid>
                                            <Grid.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#15000000" Offset="0.0" />
                                                    <GradientStop Color="#6A000000" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Grid.Background>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </CarouselView.ItemTemplate>
                        </CarouselView>

                        <VerticalStackLayout Padding="22"
                                             VerticalOptions="End"
                                             Spacing="8">
                            <Label Text="VN GO Travel"
                                   Style="{StaticResource HeroTitleLabel}" />

                            <Label Text="Khám phá vẻ đẹp Việt Nam"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#FFF4EC" />

                            <Label Text="Từ núi non hùng vĩ, vịnh biển kỳ quan, phố cổ lung linh đến những miền đất đậm bản sắc — mọi hành trình đều bắt đầu từ đây."
                                   FontSize="14"
                                   TextColor="White"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Grid.Row="1"
                                         Padding="18"
                                         Spacing="12">

                        <IndicatorView x:Name="HeroIndicator"
                                       HorizontalOptions="Center"
                                       IndicatorColor="#D7C6BC"
                                       SelectedIndicatorColor="{StaticResource BrandAccent}" />

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Bắt đầu chuyến đi của bạn"
                                       Style="{StaticResource SectionTitle}" />

                                <Label Text="Tìm điểm đến nổi bật, xem bản đồ thông minh và nghe thuyết minh theo vị trí thực tế."
                                       Style="{StaticResource BodyText}" />
                            </VerticalStackLayout>

                            <Button Grid.Column="1"
                                    Text="Mở bản đồ"
                                    Style="{StaticResource PrimaryButton}"
                                    WidthRequest="130"
                                    Clicked="OnOpenMapClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- QUICK STATS -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="50+"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BrandPrimaryDark}" />
                        <Label Text="Điểm đến"
                               Style="{StaticResource BodyText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="vi / en"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="{StaticResource NatureBlue}" />
                        <Label Text="Ngôn ngữ"
                               Style="{StaticResource BodyText}" />
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="GPS"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="{StaticResource NatureEmerald}" />
                        <Label Text="Audio guide"
                               Style="{StaticResource BodyText}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- FEATURE BANNER -->
            <Border Style="{StaticResource CardBorder}" Padding="0">
                <Grid ColumnDefinitions="*,140">
                    <VerticalStackLayout Padding="18" Spacing="8">
                        <Label Text="Du lịch thông minh, giàu cảm xúc"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <Label Text="VN GO Travel kết hợp hình ảnh, GPS, bản đồ và thuyết minh để giúp người dùng Việt Nam và quốc tế cảm nhận đất nước ta một cách trực quan và sâu sắc hơn."
                               Style="{StaticResource BodyText}" />
                    </VerticalStackLayout>

                    <Image Grid.Column="1"
                           Source="hoian.jpg"
                           Aspect="AspectFill" />
                </Grid>
            </Border>

            <!-- SECTION -->
            <Label Text="Điểm đến nổi bật"
                   Style="{StaticResource SectionTitle}" />

            <!-- DESTINATION CARD 1 -->
            <Border Style="{StaticResource CardBorder}">
                <Grid ColumnDefinitions="120,*" ColumnSpacing="14">
                    <Image Source="cauvangdanang.jpg"
                           HeightRequest="116"
                           WidthRequest="120"
                           Aspect="AspectFill" />

                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Bà Nà Hills — Cầu Vàng"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <Label Text="Biểu tượng du lịch hiện đại của Đà Nẵng, nổi bật với cây cầu vàng giữa mây núi hùng vĩ."
                               Style="{StaticResource BodyText}" />

                        <Label Text="Đà Nẵng"
                               FontSize="13"
                               TextColor="{StaticResource BrandPrimaryDark}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- DESTINATION CARD 2 -->
            <Border Style="{StaticResource CardBorder}">
                <Grid ColumnDefinitions="120,*" ColumnSpacing="14">
                    <Image Source="caobang.jpg"
                           HeightRequest="116"
                           WidthRequest="120"
                           Aspect="AspectFill" />

                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Thác Bản Giốc"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <Label Text="Một trong những thác nước đẹp nhất Đông Nam Á với dòng nước xanh ngọc và thiên nhiên kỳ vĩ."
                               Style="{StaticResource BodyText}" />

                        <Label Text="Cao Bằng"
                               FontSize="13"
                               TextColor="{StaticResource BrandPrimaryDark}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- DESTINATION CARD 3 -->
            <Border Style="{StaticResource CardBorder}">
                <Grid ColumnDefinitions="120,*" ColumnSpacing="14">
                    <Image Source="chuabaidinh.jpg"
                           HeightRequest="116"
                           WidthRequest="120"
                           Aspect="AspectFill" />

                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Tràng An"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <Label Text="Quần thể danh thắng nổi tiếng với non nước, hang động và vẻ đẹp thanh bình rất riêng của Ninh Bình."
                               Style="{StaticResource BodyText}" />

                        <Label Text="Ninh Bình"
                               FontSize="13"
                               TextColor="{StaticResource BrandPrimaryDark}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- DESTINATION CARD 4 -->
            <Border Style="{StaticResource CardBorder}">
                <Grid ColumnDefinitions="120,*" ColumnSpacing="14">
                    <Image Source="hoian.jpg"
                           HeightRequest="116"
                           WidthRequest="120"
                           Aspect="AspectFill" />

                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Phố cổ Hội An"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <Label Text="Phố cổ lung linh ánh đèn, sông Hoài yên bình và bầu không khí văn hóa rất đặc trưng của miền Trung."
                               Style="{StaticResource BodyText}" />

                        <Label Text="Quảng Nam"
                               FontSize="13"
                               TextColor="{StaticResource BrandPrimaryDark}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- CTA -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Sẵn sàng khám phá Việt Nam?"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />

                    <Label Text="Mở bản đồ để bắt đầu hành trình, theo dõi vị trí hiện tại và lắng nghe những câu chuyện về các địa danh nổi tiếng."
                           Style="{StaticResource BodyText}" />

                    <Button Text="Khám phá trên bản đồ"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnOpenMapClicked" />
                </VerticalStackLayout>
            </Border>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>