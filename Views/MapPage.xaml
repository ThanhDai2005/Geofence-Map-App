<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="MauiApp1.Views.MapPage">

    <Grid>
        <!-- MAP -->
        <maps:Map
        x:Name="Map"
        IsShowingUser="True"
        MapType="Street" />

        <!-- LANGUAGE SWITCH -->
        <HorizontalStackLayout
        Padding="10"
        Spacing="10"
        BackgroundColor="White"
        VerticalOptions="Start">

            <Button Text="Tiếng Việt"
                Clicked="OnVietnameseClicked" />
            <Button Text="English"
                Clicked="OnEnglishClicked" />
        </HorizontalStackLayout>

        <!-- BOTTOM PANEL -->
        <Border IsVisible="{Binding IsPoiPanelVisible}"
            VerticalOptions="End"
            Margin="20,0,20,30"
            Padding="20"
            BackgroundColor="White"
            StrokeShape="RoundRectangle 20">

            <VerticalStackLayout Spacing="10">
                <Label Text="{Binding SelectedPoi.Name}" FontSize="20" FontAttributes="Bold"/>

                <Label Text="{Binding SelectedPoi.NarrationShort}"
                   MaxLines="3"
                   LineBreakMode="TailTruncation"/>

                <Grid ColumnDefinitions="*,*">
                    <Button Text="Nghe chi tiết"
                        Clicked="OnListenDetailedClicked"/>

                    <Button Grid.Column="1"
                        Text="Đóng"
                        Clicked="OnClosePanelClicked"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
    
</ContentPage>