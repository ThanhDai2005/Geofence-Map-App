<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    x:Class="MauiApp1.Views.MapPage"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <Grid>
        <maps:Map x:Name="Map"
                  IsShowingUser="True"
                  MapType="Street" />

        <!-- Top floating bar -->
        <Border Margin="16,48,16,0"
                Padding="12"
                BackgroundColor="#FDFBF9EE"
                Stroke="{StaticResource BorderLight}"
                StrokeShape="RoundRectangle 24"
                VerticalOptions="Start">

            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <Border BackgroundColor="#F8E9E0" StrokeThickness="0" Padding="10" StrokeShape="RoundRectangle 16">
                    <Label Text="🧭" FontSize="18" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="Bản đồ Việt Nam" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource BrandPrimaryDark}" />
                    <Label Text="Khám phá bằng vị trí và âm thanh" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <Button Grid.Column="2" Text="VN" Clicked="OnVietnameseClicked"
                        WidthRequest="46" HeightRequest="40" CornerRadius="14"
                        BackgroundColor="#F4ECE7" TextColor="{StaticResource BrandPrimaryDark}" />

                <Button Grid.Column="3" Text="EN" Clicked="OnEnglishClicked"
                        WidthRequest="46" HeightRequest="40" CornerRadius="14"
                        BackgroundColor="#F4ECE7" TextColor="{StaticResource BrandPrimaryDark}" />
            </Grid>
        </Border>

        <!-- Bottom POI panel -->
        <Border x:Name="BottomPanel"
                VerticalOptions="End"
                Margin="16,0,16,20"
                BackgroundColor="White"
                Stroke="{StaticResource BorderLight}"
                StrokeShape="RoundRectangle 28">

            <Border.Shadow>
                <Shadow Brush="{StaticResource ShadowColor}" Opacity="0.18" Offset="0,8" Radius="18" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto">
                <BoxView HeightRequest="4"
                         WidthRequest="42"
                         HorizontalOptions="Center"
                         Margin="0,10"
                         BackgroundColor="#D8C8C0"
                         CornerRadius="2" />

                <VerticalStackLayout Grid.Row="1" Padding="20,8,20,6" Spacing="8">
                    <Label Text="{Binding SelectedPoi.Name}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                    <Label Text="{Binding SelectedPoi.NarrationShort}" FontSize="14" TextColor="{StaticResource TextSecondary}" MaxLines="3" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <Grid Grid.Row="2" Padding="16" ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Text="▶ Nghe chi tiết"
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnListenDetailedClicked" />
                    <Button Grid.Column="1"
                            Text="Đóng"
                            Style="{StaticResource SecondaryButton}"
                            Clicked="OnClosePanelClicked" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>