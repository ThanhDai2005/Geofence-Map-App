<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.AdminToolsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Quản trị"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label Text="Quản trị viên"
                   Style="{StaticResource PageTitleLabel}" />
            <Label Text="Bảng điều khiển moderation dùng AdminWeb hoặc API /api/v1/admin/... . Tab này chỉ dành cho tài khoản ADMIN."
                   Style="{StaticResource BodyText}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
