<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:MauiApp1.ViewModels"
    x:DataType="vm:LoginViewModel"
    Title="Đăng nhập"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <Grid>
        <!-- BACKGROUND DECORATION -->
        <BoxView VerticalOptions="Start" HeightRequest="300">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource BrandPrimary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource BrandPrimaryDark}" Offset="0.8" />
                    <GradientStop Color="{StaticResource SurfaceBackground}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView>
            <VerticalStackLayout Padding="24,60,24,40" Spacing="0">

                <!-- HERO SECTION -->
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center" Margin="0,0,0,32">
                    <Border StrokeShape="RoundRectangle 24" 
                            HeightRequest="80" 
                            WidthRequest="80" 
                            BackgroundColor="White" 
                            Padding="12"
                            HorizontalOptions="Center">
                        <Image Source="travel_login_hero.png" 
                               Aspect="AspectFit" />
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.1" />
                        </Border.Shadow>
                    </Border>

                    <Label Text="VN GO Travel" 
                           TextColor="White" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" />
                    <Label Text="Khám phá Việt Nam theo cách của bạn" 
                           TextColor="White" 
                           Opacity="0.8"
                           FontSize="14" 
                           HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- LOGIN CARD -->
                <Border Style="{StaticResource CardBorder}" Padding="28">
                    <VerticalStackLayout Spacing="24">
                        
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Chào mừng trở lại!" 
                                   Style="{StaticResource SectionTitle}" 
                                   FontSize="20" 
                                   HorizontalOptions="Start" />
                            <Label Text="Đăng nhập để tiếp tục hành trình" 
                                   TextColor="{StaticResource TextSecondary}" 
                                   FontSize="14" />
                        </VerticalStackLayout>

                        <!-- INPUT FIELDS -->
                        <VerticalStackLayout Spacing="16">
                            
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Email"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}"
                                       Margin="4,0" />
                                <Border Stroke="{StaticResource BrandDark}"
                                        StrokeThickness="0.5"
                                        Padding="12,4"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource SurfaceCard}">
                                    <Entry Text="{Binding Email}"
                                           Placeholder="email@example.com"
                                           PlaceholderColor="{StaticResource TextSecondary}"
                                           Keyboard="Email"
                                           IsEnabled="{Binding IsNotBusy}"
                                           TextColor="{StaticResource TextPrimary}" />
                                </Border>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="6">
                                <Label Text="Mật khẩu"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextSecondary}"
                                       Margin="4,0" />
                                <Border Stroke="{StaticResource BrandDark}"
                                        StrokeThickness="0.5"
                                        Padding="12,4"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{StaticResource SurfaceCard}">
                                    <Entry Text="{Binding Password}"
                                           Placeholder="••••••••"
                                           PlaceholderColor="{StaticResource TextSecondary}"
                                           IsPassword="True"
                                           IsEnabled="{Binding IsNotBusy}"
                                           TextColor="{StaticResource TextPrimary}" />
                                </Border>
                            </VerticalStackLayout>

                        </VerticalStackLayout>

                        <!-- ERROR MESSAGE -->
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#FF5252"
                               FontSize="13"
                               HorizontalOptions="Center"
                               IsVisible="{Binding HasError}"
                               Margin="0,-8,0,0" />

                        <!-- BUTTONS -->
                        <VerticalStackLayout Spacing="12">
                            
                            <Grid>
                                <Button Text="Đăng nhập"
                                        Style="{StaticResource PrimaryButton}"
                                        Command="{Binding LoginCommand}"
                                        IsEnabled="{Binding IsNotBusy}" />
                                
                                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                                   IsVisible="{Binding IsBusy}"
                                                   Color="White"
                                                   VerticalOptions="Center"
                                                   HorizontalOptions="Center"
                                                   HeightRequest="24"
                                                   WidthRequest="24" />
                            </Grid>

                            <Button Text="Tạo tài khoản mới"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnOpenRegisterClicked"
                                    IsEnabled="{Binding IsNotBusy}" />

                            <Button Text="Quay lại"
                                    Style="{StaticResource SecondaryButton}"
                                    Clicked="OnCloseClicked"
                                    IsEnabled="{Binding IsNotBusy}" />

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- FOOTER -->
                <Label Text="Chưa có tài khoản? Bấm Tạo tài khoản mới để đăng ký." 
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"
                       HorizontalOptions="Center"
                       Margin="0,32,0,0" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
