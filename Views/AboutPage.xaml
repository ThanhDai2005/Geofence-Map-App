<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="MauiApp1.Views.AboutPage"
    Title="Giới thiệu"
    BackgroundColor="{StaticResource SurfaceBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20,24,20,120" Spacing="28">

            <!-- HERO SECTION -->
            <Border Style="{StaticResource CardBorder}" Padding="0" StrokeThickness="0">
                <Grid RowDefinitions="240,Auto">
                    <!-- HERO BACKGROUND -->
                    <Grid Grid.RowSpan="2">
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{StaticResource BrandPrimaryDark}" Offset="0.0" />
                                <GradientStop Color="{StaticResource NatureEmerald}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Grid.Background>
                    </Grid>

                    <Image Grid.Row="0"
                           Source="logotravelvn.png"
                           Aspect="AspectFit"
                           Margin="40"
                           Opacity="0.95" />

                    <VerticalStackLayout Grid.Row="1"
                                         Padding="24,0,24,28"
                                         Spacing="12">
                        <Label Text="VN GO Travel"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />

                        <Label Text="Khám phá vẻ đẹp Việt Nam qua lăng kính công nghệ"
                               FontSize="16"
                               TextColor="#EAEAEA"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- MISSION SECTION -->
            <VerticalStackLayout Spacing="16">
                <Label Text="Tầm nhìn của chúng tôi"
                       Style="{StaticResource SectionTitle}" />

                <Border Style="{StaticResource CardBorder}" Padding="24">
                    <VerticalStackLayout Spacing="20">
                        <Label Text="Việt Nam là đất nước của núi non hùng vĩ và những phố cổ đậm chiều sâu văn hóa. VN GO Travel được xây dựng để giới thiệu vẻ đẹp đó bằng một trải nghiệm trực quan, hiện đại và truyền cảm hứng hơn."
                               Style="{StaticResource BodyText}"
                               FontSize="16"
                               TextColor="{StaticResource TextPrimary}" />

                        <!-- AUDIO CONTROLS -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Button Text="🎧 Nghe lời giới thiệu"
                                    Style="{StaticResource PrimaryButton}"
                                    Clicked="OnPlayIntroClicked" />

                            <Button Grid.Column="1"
                                    Text="⏹"
                                    Style="{StaticResource SecondaryButton}"
                                    WidthRequest="60"
                                    Clicked="OnStopIntroClicked" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- FEATURES GRID -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Border Style="{StaticResource CardBorder}" Padding="18">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🏞" FontSize="28" />
                        <Label Text="Thiên nhiên"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource NatureEmerald}" />
                        <Label Text="Khám phá kỳ quan, núi non và biển cả Việt Nam."
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="18">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="🗺" FontSize="28" />
                        <Label Text="Thông minh"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource NatureBlue}" />
                        <Label Text="Theo dõi vị trí và nghe thuyết minh tự động."
                               FontSize="13"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- VALUES SECTION -->
            <VerticalStackLayout Spacing="16">
                <Label Text="Giá trị cốt lõi"
                       Style="{StaticResource SectionTitle}" />

                <Border Style="{StaticResource CardBorder}">
                    <VerticalStackLayout Spacing="16">
                        
                        <HorizontalStackLayout Spacing="12">
                            <Border BackgroundColor="{StaticResource SurfaceSoft}" Padding="8" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                                <Label Text="🎨" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Tôn vinh vẻ đẹp thiên nhiên Việt Nam" 
                                   Style="{StaticResource BodyText}" 
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="12">
                            <Border BackgroundColor="{StaticResource SurfaceSoft}" Padding="8" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                                <Label Text="🚀" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Trải nghiệm khám phá sinh động" 
                                   Style="{StaticResource BodyText}" 
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="12">
                            <Border BackgroundColor="{StaticResource SurfaceSoft}" Padding="8" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                                <Label Text="💡" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="Kết hợp công nghệ với cảm hứng" 
                                   Style="{StaticResource BodyText}" 
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- FOOTER TAGLINE -->
            <Label Text="Một hành trình số tinh tế — VN GO Travel"
                   FontSize="13"
                   FontAttributes="Italic"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>